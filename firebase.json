{
  "hosting": {
    "public": "XRewardsWeb/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "redirects": [
      { "source": "/support", "destination": "/support.html", "type": 301 },
      { "source": "/privacy-policy", "destination": "/privacy-policy.html", "type": 301 }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
